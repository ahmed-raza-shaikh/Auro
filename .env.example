# Environment variables for local development
# NEVER commit this file to Git. It is listed in .gitignore.
#
# Copy to .env and populate values:
#   cp .env.example .env
#   vim .env

# ── Slack Webhook URL ─────────────────────────────────────────────────────────
# Generate at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WORKSPACE/WEBHOOK

# ── S3 bucket for PDF report storage ─────────────────────────────────────────
# Must exist and the Lambda role must have PutObject permission
S3_REPORTS_BUCKET=your-compliance-reports-bucket-name

# ── AWS configuration ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=your-dev-aws-profile

# ── Logging verbosity for local runs ─────────────────────────────────────────
LOG_LEVEL=DEBUG
