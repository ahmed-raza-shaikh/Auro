# ─────────────────────────────────────────────────────────────
# Auro — .gitignore
# ─────────────────────────────────────────────────────────────

# Environment secrets — NEVER commit
.env
*.env

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Build artifacts
.build/
*.zip
*.egg
*.egg-info/
dist/
build/

# Test coverage
.coverage
.coverage.*
.coverage_html/
htmlcov/
.pytest_cache/
coverage.xml

# Type checking
.mypy_cache/
.dmypy.json

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Lambda temp output (local dev)
/tmp/*.pdf
